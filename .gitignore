############################
# OS / Windows
############################
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

############################
# macOS（你项目里出现了.DS_Store）
############################
.DS_Store

############################
# Python cache / compiled
############################
__pycache__/
*.py[cod]
*$py.class

############################
# Python virtual env
############################
.venv/
venv/
env/
ENV/

############################
# Build / dist
############################
build/
dist/
*.egg-info/

############################
# Logs / runtime output
############################
logs/
*.log

############################
# Runtime outputs
############################
output.srt
data/transcripts/
tests/uploads/

############################
# Env / secrets
############################
config/.env
.env

############################
# IDE - JetBrains / PyCharm
############################
.idea/
*.iml

############################
# Node (你有 package-lock.json)
############################
node_modules/

############################
# Models (大型模型文件建议不要入库)
############################
models/

# 如果你希望保留 models 目录结构，但不提交模型权重：
# models/**/*
# !models/**/.gitattributes
# !models/**/README.md
# !models/**/requirements.txt
# !models/**/config.yaml
# !models/**/configuration.json
# !models/**/tokens.json
# !models/**/tokens.txt
# !models/**/vocab.txt
# !models/**/special_tokens_map.json
# !models/**/tokenizer.json
# !models/**/tokenizer_config.json
# !models/**/config.json
# !models/**/modules.json

############################
# Large model weights (保险)
############################
*.pt
*.bin
*.safetensors
*.mvn
*.mdl

############################
# Testing caches
############################
.pytest_cache/
.mypy_cache/
.cache/
