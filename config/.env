# RAG runtime defaults
# By default the new RAG scripts use embedded local Qdrant storage under data/qdrant.
# Set RAG_QDRANT_PREFER_LOCAL=false and QDRANT_URL=http://host:6333 to use a remote Qdrant server.

# RAG_QDRANT_PREFER_LOCAL=true
# RAG_QDRANT_LOCAL_PATH=E:/Study-agent-new-master/data/qdrant/speech_transcript_chunks
# QDRANT_URL=http://localhost:6333
# RAG_QDRANT_COLLECTION=speech_transcript_chunks

# Transcript source and chunking
# RAG_TRANSCRIPT_ROOT=E:/Study-agent-new-master/data/transcripts
# RAG_CHUNK_MAX_CHARS=500
# RAG_CHUNK_OVERLAP_RECORDS=1
# RAG_CHUNK_MIN_CHARS=80
# RAG_REALTIME_INDEXING_ENABLED=true
# RAG_REALTIME_FLUSH_RECORDS=3
# RAG_REALTIME_FLUSH_CHARS=300
# RAG_REALTIME_FLUSH_INTERVAL_SECONDS=20

# Embedding model
# RAG_EMBED_MODEL_NAME=E:/Study-agent-new-master/models/embedding/bge-small-zh-v1.5

# Optional OpenAI-compatible LLM for answer generation
# Configured for DeepSeek by default.
RAG_ENABLE_LLM=true
RAG_LLM_PROVIDER=deepseek
RAG_LLM_MODEL=deepseek-chat
RAG_LLM_API_KEY=sk-718f791e10464fadb385819d1b9ff5ed
RAG_LLM_API_BASE=https://api.deepseek.com
RAG_LLM_TEMPERATURE=0.1
RAG_LLM_MAX_TOKENS=512
